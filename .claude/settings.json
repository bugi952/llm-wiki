{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(* --force *)",
      "Bash(DROP TABLE *)",
      "Bash(DELETE FROM *)",
      "Bash(* 0.0.0.0 *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Read(**/*private*key*)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(pip install *)",
      "Bash(git push --force *)"
    ],
    "allow": [
      "Read(**/*.py)",
      "Read(**/*.md)",
      "Read(**/*.yaml)",
      "Read(**/*.json)",
      "Read(**/*.txt)",
      "Read(**/*.sql)",
      "Glob(*)",
      "Grep(*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$TOOL_INPUT\" | grep -qiE '(rm -rf|drop table|DELETE FROM|truncate table|--force|0\\.0\\.0\\.0)' && echo 'BLOCK: 위험 명령 감지' && exit 1 || exit 0"
          }
        ]
      },
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'PRE-PUSH: /pre-push 스킬을 먼저 실행하세요. skip review로 우회 가능.'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== Session Start ==='; head -5 docs/00_project-brief.md 2>/dev/null; echo '--- Current Phase ---'; head -10 .claude/commands/build-phase.md 2>/dev/null"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[DRIFT CHECK] 변경된 파일이 docs/ 설계와 일치하는지 확인할 것. 임의 확장/변경은 code-gotchas 설계 충실도 감점 대상.'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[COMPACT] CLAUDE.md 재확인 + 현재 작업 상태 복구할 것.'"
          }
        ]
      }
    ]
  }
}
